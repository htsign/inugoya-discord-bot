{
  "$schema": "https://biomejs.dev/schemas/2.4.10/schema.json",
  "assist": {
    "actions": {
      "source": {
        "organizeImports": {
          "level": "on",
          "options": {
            "groups": [
              { "source": ":NODE:" },
              { "source": ":PACKAGE:" },
              { "source": ":URL:" },
              { "source": ":ALIAS:" },
              { "source": ":PATH:" }
            ]
          }
        }
      }
    }
  },
  "formatter": {
    "enabled": false
  },
  "linter": {
    "enabled": true,
    "rules": {
      "suspicious": {
        "noAssignInExpressions": "off"
      },
      "style": {
        "useImportType": "on"
      }
    }
  },
  "files": {
    "includes": [
      "**",
      "!!tsconfig.json",
      "!!**/node_modules",
      "!!.vscode"
    ]
  }
}
